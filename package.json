{
  "name": "scratch-orm",
  "version": "0.1.0",
  "description": "A lightweight TypeScript ORM built from scratch.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "scratchorm": "node dist/cli/index.js"
  },
  "files": [
    "dist/cli",
    "dist/client",
    "dist/config",
    "dist/docker",
    "dist/generator",
    "dist/migrate",
    "dist/parser",
    "dist/types",
    "dist/index.js",
    "dist/index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsc -p tsconfig.json && node dist/cli/index.js dev",
    "generate": "tsc -p tsconfig.json && node dist/cli/index.js generate",
    "migrate": "tsc -p tsconfig.json && node dist/cli/index.js migrate",
    "example": "tsc -p tsconfig.json && node dist/example/index.js"
  },
  "keywords": [
    "orm",
    "typescript",
    "postgresql",
    "docker",
    "type-safe",
    "migrations",
    "database"
  ],
  "author": "Aditya Saini",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SainiAdi-04/ScratchORM"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "dockerode": "^4.0.9",
    "pg": "^8.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
