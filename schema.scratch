model User {
  id Int @id @default(autoincrement())
  email String @unique
  name String @optional
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
}

model Post {
  id Int @id @default(autoincrement())
  title String
  content String @optional
  published Boolean @default(false)
  createdAt DateTime @default(now())
}
